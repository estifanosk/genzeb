{
  "extends": "@electron-toolkit/tsconfig/tsconfig.node.json",
  "include": ["electron.vite.config.*", "src/main/**/*", "src/preload/**/*", "../core/**/*"],
  "compilerOptions": {
    "composite": true,
    "types": ["electron-vite/node"],
    "baseUrl": ".",
    "paths": {
      "@core/*": ["../core/*"],
      "date-fns": ["node_modules/date-fns"],
      "papaparse": ["node_modules/papaparse"],
      "uuid": ["node_modules/uuid"]
    }
  }
}
